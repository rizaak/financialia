{
  "name": "financial-ia",
  "private": true,
  "engines": {
    "node": ">=20.11"
  },
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "db:validate": "env DATABASE_URL=\"postgresql://user:pass@127.0.0.1:5432/financialia\" prisma validate",
    "db:generate": "env DATABASE_URL=\"postgresql://user:pass@127.0.0.1:5432/financialia\" prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:migrate:sql": "env DATABASE_URL=\"postgresql://user:pass@127.0.0.1:5432/financialia\" prisma migrate diff --from-empty --to-schema-datamodel prisma/schema.prisma --script",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "db:logs": "docker compose logs -f postgres",
    "dev:api": "npm run start:dev -w @financial-ia/api",
    "dev:web": "npm run dev -w @vidya/web",
    "build:api": "npm run build -w @financial-ia/api",
    "build:web": "npm run build -w @vidya/web",
    "prepare": "prisma generate"
  },
  "devDependencies": {
    "prisma": "^6.19.2",
    "sharp": "^0.34.5"
  },
  "dependencies": {
    "@prisma/client": "^6.19.2"
  }
}
