# PostgreSQL (Prisma) — credenciales alineadas con docker-compose.yml
DATABASE_URL="postgresql://financialia:financialia@localhost:5432/financialia?schema=public"

# API Nest (apps/api)
API_PORT=3000
FRONTEND_ORIGIN=http://localhost:5173

# Frontend (apps/web/.env) — copiar a apps/web/.env
# VITE_API_URL=http://localhost:3000
# VITE_AUTH0_DOMAIN=xxx.auth0.com
# VITE_AUTH0_CLIENT_ID=
# VITE_AUTH0_AUDIENCE=https://tu-api-identifier
# VITE_DEV_ACCESS_TOKEN= (solo sin SPA Auth0)

# Auth0 — API (RS256 + JWKS)
# AUTH0_ISSUER_URL = claim "iss" del access token (con custom domain usa https://login.tudominio.pro/)
# AUTH0_AUDIENCE = identificador de la API en Auth0; debe ser IGUAL a VITE_AUTH0_AUDIENCE (ambos .env)
AUTH0_ISSUER_URL=https://YOUR_TENANT.auth0.com/
AUTH0_AUDIENCE=https://your-api-identifier

# IA — parser de gastos (AiParserService). Define al menos una API key.
# AI_PROVIDER=openai
# OPENAI_API_KEY=
# Modelo OpenAI (AI_MODEL tiene prioridad; alternativa legacy: OPENAI_MODEL)
# AI_MODEL=gpt-4o
# OPENAI_MODEL=gpt-4o-mini
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-1.5-flash
