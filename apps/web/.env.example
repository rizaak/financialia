# URL del API Nest (sin barra final). Si lo dejas vacío, se usa http://localhost:3000
VITE_API_URL=http://localhost:3000

# Auth0 SPA (recomendado). Mismo Audience que AUTH0_AUDIENCE en el API.
VITE_AUTH0_DOMAIN=YOUR_TENANT.auth0.com
VITE_AUTH0_CLIENT_ID=
VITE_AUTH0_AUDIENCE=https://your-api-identifier

# Solo si NO usas las variables de Auth0 arriba: token manual (no subir a git)
VITE_DEV_ACCESS_TOKEN=
